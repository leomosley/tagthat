---
import Layout from "../layouts/layout.astro";
import Header from "../components/header.astro";
import CopyButton from "../components/copy-button.tsx";
import TerminalDemo from "../components/terminal-demo.astro";
---

<Layout>
  <Header />

  <main
    class="flex min-h-screen flex-col items-center justify-start px-4 sm:px-6 pt-20 sm:pt-28 pb-16 sm:pb-24"
  >
    <!-- Hero -->
    <section class="flex flex-col items-center gap-3 text-center w-full">
      <!-- Title -->
      <h1
        class="animate-fade-up delay-1 text-3xl sm:text-5xl md:text-6xl font-light tracking-tight text-white leading-tight sm:whitespace-nowrap"
      >
        Add a <span class="reveal-group"
          ><span class="reveal-top"
            >producer tag<span class="reveal-trigger" style="color:#f472b6">*</span></span
          ><span class="reveal-bottom">sound effect</span></span
        > to your pushes.
      </h1>

      <!-- Subtitle -->
      <p
        class="animate-fade-up delay-2 text-sm sm:text-base text-neutral-500 max-w-xs sm:max-w-sm leading-relaxed"
      >
        A git pre-push hook that plays your personal audio tag on every push.
        One command to set up.
      </p>

      <!-- CTA -->
      <div class="animate-fade-up delay-3 mt-2">
        <CopyButton client:load />
      </div>
    </section>

    <!-- Terminal demo -->
    <section class="animate-fade-up delay-4 mt-10 sm:mt-16 w-full max-w-4xl">
      <TerminalDemo />
    </section>
  </main>
</Layout>

<script>
  const group = document.querySelector<HTMLElement>(".reveal-group");
  const trigger = document.querySelector<HTMLElement>(".reveal-trigger");
  const bottom = document.querySelector<HTMLElement>(".reveal-bottom");
  if (group && trigger && bottom) {
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      group.classList.add("active");
    });
    bottom.addEventListener("click", () => {
      group.classList.remove("active");
    });
  }
</script>
