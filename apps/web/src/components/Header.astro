---
let stars: number | null = null;

try {
  const res = await fetch("https://api.github.com/repos/leomosley/tagthat", {
    headers: { Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const data = await res.json();
    stars = data.stargazers_count ?? null;
  }
} catch {
  // ignore
}
---

<header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
  <a
    href="https://mosly.dev"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="mosly.dev"
    class="opacity-70 hover:opacity-100 transition-opacity duration-200"
  >
    <img src="/icon.png" alt="tagthat icon" class="h-7 w-7 rounded-md" />
  </a>

  <a
    href="https://github.com/leomosley/tagthat"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 rounded-full border border-white/[0.08] bg-white/[0.04] px-3.5 py-1.5 text-xs text-neutral-400 backdrop-blur-md transition-all duration-200 hover:border-white/[0.15] hover:text-neutral-200"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="h-3.5 w-3.5 shrink-0"
      aria-hidden="true"
    >
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
    </svg>
    GitHub
    {
      stars !== null && stars > 0 && (
        <>
          <span class="w-px h-3 bg-white/10" />
          <span class="flex items-center gap-1 text-neutral-500">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-3 w-3 text-yellow-500/70"
              aria-hidden="true"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            {stars >= 1000 ? `${parseFloat((stars / 1000).toFixed(1))}K` : stars}
          </span>
        </>
      )
    }
  </a>
</header>
